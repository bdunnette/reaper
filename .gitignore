# .gitignore for Python and uv project

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
bin/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Pytest / Coverage / Tox
.tox/
.nosetests
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.log
.pytest_cache/
.pytest_cache

# Virtual Environments
.venv/
venv/
ENV/
env/

# IDE / Editor configurations
.vscode/
.idea/
*.swp
*.swo

# Local CLI cache
.antigravitycli/
